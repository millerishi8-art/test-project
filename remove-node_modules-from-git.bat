@echo off
cd /d "%~dp0"
echo Removing node_modules from Git index (files stay on disk)...
echo.
echo Root node_modules...
git rm -r --cached node_modules 2>nul
if %errorlevel% neq 0 echo   (not tracked - OK)
echo client/node_modules...
git rm -r --cached client/node_modules 2>nul
if %errorlevel% neq 0 echo   (not tracked - OK)
echo server/node_modules...
git rm -r --cached server/node_modules 2>nul
if %errorlevel% neq 0 echo   (not tracked - OK)
echo.
echo Done. Next steps:
echo   git add .gitignore
echo   git commit -m "Stop tracking node_modules"
pause
